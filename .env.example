# Copy to .env and adjust. Used by docker-compose and local dev.

# PostgreSQL (docker-compose & local DATABASE_URL host)
POSTGRES_USER=jobboard
POSTGRES_PASSWORD=jobboard
POSTGRES_DB=jobboard

# Backend — use host port when running API on your machine; use `postgres` hostname only inside Docker network
DATABASE_URL=postgresql://jobboard:jobboard@localhost:5432/jobboard

# Default tenant for job CRUD until auth chooses an organization (matches bootstrap migration)
DEFAULT_ORGANIZATION_ID=00000000-0000-0000-0000-000000000001

PORT=3000

# Frontend — browser calls this URL (API exposed on host)
VITE_API_URL=http://localhost:3000
